{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/api/launch-call$",
      "dest": "/api/launch-call.js"
    },
    {
      "src": "^/api/call-webhook$",
      "dest": "/api/call-webhook.js"
    },
    {
      "src": "^/api/call-status$",
      "dest": "/api/call-status.js"
    },
    {
      "src": "^/api/schedule-call$",
      "dest": "/api/schedule-call.js"
    },
    {
      "src": "^/api/dispatch-scheduled$",
      "dest": "/api/dispatch-scheduled.js"
    },
    {
      "src": "^/api/setter-launch$",
      "dest": "/api/setter-launch.js"
    },
    {
      "src": "^/api/setter-webhook$",
      "dest": "/api/setter-webhook.js"
    },
    {
      "src": "^/api/setter-slots$",
      "dest": "/api/setter-slots.js"
    },
    {
      "src": "^/api/setter-book$",
      "dest": "/api/setter-book.js"
    },
    {
      "src": "^/api/test-call$",
      "dest": "/api/test-call.js"
    },
    {
      "src": "^/api/mailgun-inbound$",
      "dest": "/api/mailgun-inbound.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "crons": [
    {
      "path": "/api/dispatch-scheduled",
      "schedule": "*/15 13-22 * * 1-5"
    }
  ]
}
