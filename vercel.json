{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/api/launch-call$",
      "dest": "/api/launch-call.js"
    },
    {
      "src": "^/api/call-webhook$",
      "dest": "/api/call-webhook.js"
    },
    {
      "src": "^/api/call-status$",
      "dest": "/api/call-status.js"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/api/$1.js"
    }
  ]
}
