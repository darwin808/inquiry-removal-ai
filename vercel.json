{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/api/launch-call$",
      "dest": "/api/launch-call.js"
    },
    {
      "src": "^/api/call-webhook$",
      "dest": "/api/call-webhook.js"
    },
    {
      "src": "^/api/call-status$",
      "dest": "/api/call-status.js"
    },
    {
      "src": "^/api/schedule-call$",
      "dest": "/api/schedule-call.js"
    },
    {
      "src": "^/api/dispatch-scheduled$",
      "dest": "/api/dispatch-scheduled.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "crons": [
    {
      "path": "/api/dispatch-scheduled",
      "schedule": "*/15 13-22 * * 1-5"
    }
  ]
}
